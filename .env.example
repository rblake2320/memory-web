# MemoryWeb Configuration
# Copy this file to .env and customize for your setup
#
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Docker Compose users: leave as-is (matches docker-compose.yml defaults)
# Manual users: change to your PostgreSQL credentials
MW_DATABASE_URL=postgresql://memoryweb:memoryweb@localhost:5432/memoryweb
MW_DB_SCHEMA=memoryweb

# ── Redis / Celery ─────────────────────────────────────────────────────────────
MW_REDIS_URL=redis://localhost:6379/1
MW_CELERY_BROKER_URL=redis://localhost:6379/1
MW_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Ollama (LLM for pipeline) ──────────────────────────────────────────────────
# Ollama is used to segment conversations, extract memories, and tag content.
# Without it, search and browse work but new data won't be processed.
MW_OLLAMA_BASE_URL=http://localhost:11434
# Smaller model (3GB) — good default. Larger models give richer memories:
#   qwen2.5:7b (5GB), llama3.1:8b (5GB), mistral:7b (4GB)
MW_OLLAMA_MODEL=llama3.2:3b

# ── Embeddings ─────────────────────────────────────────────────────────────────
# sentence-transformers model for semantic (Tier 3) search.
# The model is downloaded automatically on first run (~90MB).
MW_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
MW_EMBED_DIM=384

# ── Server ─────────────────────────────────────────────────────────────────────
MW_PORT=8100

# ── Source Data Paths (optional) ───────────────────────────────────────────────
# These are optional. You can also upload files via the dashboard.
# Claude Code sessions directory (contains .jsonl session files):
# MW_SESSIONS_DIR=/home/user/.claude/projects/
# AI Army shared chat directory:
# MW_SHARED_CHAT_DIR=/path/to/shared/chat
# SQLite memory database:
# MW_SQLITE_MEMORY_PATH=/path/to/memory.db

# ── Security ───────────────────────────────────────────────────────────────────
# API key for protecting the API (optional — empty = no auth, good for local use)
# When set, all /api/ requests need header: X-API-Key: your-key-here
# MW_API_KEY=change-me-to-a-strong-secret

# Allowed origins for CORS (comma-separated, or * for any)
# MW_CORS_ORIGINS=http://localhost:8100,https://yourdomain.com
MW_CORS_ORIGINS=*

# ── Pipeline Tuning ────────────────────────────────────────────────────────────
# (defaults are fine for most users)
# MW_SEGMENT_MAX_MESSAGES=20
# MW_SEGMENT_GAP_MINUTES=30
# MW_BATCH_SIZE=500
# MW_EMBED_BATCH_SIZE=64
